# TMDB (free key from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# Database
POSTGRES_PASSWORD=showtrack

# Security
JWT_SECRET=change-me-to-a-long-random-string

# Domains (Dokploy / Traefik)
API_DOMAIN=api.yourdomain.com
WEB_DOMAIN=app.yourdomain.com
MEDIA_DOMAIN=media.yourdomain.com

# URLs
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
MEDIA_URL=https://media.yourdomain.com
CORS_ORIGINS=https://app.yourdomain.com

# Push (optional — mount secrets in infra/secrets/)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRODUCTION=true
EPISODE_CHECK_INTERVAL=1h

# Firebase Web Push (optional — for PWA notifications)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
